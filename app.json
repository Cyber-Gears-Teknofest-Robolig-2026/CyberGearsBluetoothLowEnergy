{
  "expo": {
    "name": "Cyber Gears BlueTooth Low Energy",
    "slug": "CyberGearsBlueToothLowEnergy",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#E6DFCD",
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "dark": {
            "image": "./assets/images/icon.png",
            "backgroundColor": "#B8B2A4",
            "imageWidth": 200
          }
        }
      ]
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6DFCD",
        "foregroundImage": "./assets/images/icon-foreground.png",
        "monochromeImage": "./assets/images/icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.cybergears.CyberGearsBlueToothLowEnergy"
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "lang": "tr"
    }
  }
}