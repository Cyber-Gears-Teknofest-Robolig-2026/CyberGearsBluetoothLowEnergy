{
  "name": "cybergearsbluetoothlowenergy",
  "version": "1.0.0",
  "main": "src/index.ts",
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@miblanchard/react-native-slider": "^2.6.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "buffer": "^6.0.3",
    "expo": "^56.0.12",
    "expo-dev-client": "~56.0.20",
    "expo-font": "~56.0.5",
    "expo-screen-orientation": "~56.0.5",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "^56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-ble-plx": "^3.5.0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-pager-view": "8.0.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-tab-view": "^4.3.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "@types/react-native-vector-icons": "^6.4.18",
    "cross-var": "^1.1.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "dotenv -- cross-var expo start --host %EXPO_PUBLIC_HOST% --port %EXPO_PUBLIC_PORT% %EXPO_PUBLIC_LAUNCH_MODE%",
    "android": "dotenv -- cross-var expo start --android --host %EXPO_PUBLIC_HOST% --port %EXPO_PUBLIC_PORT% %EXPO_PUBLIC_LAUNCH_MODE%",
    "ios": "dotenv -- cross-var expo start --ios --host %EXPO_PUBLIC_HOST% --port %EXPO_PUBLIC_PORT% %EXPO_PUBLIC_LAUNCH_MODE%",
    "web": "dotenv -- cross-var expo start --web --host %EXPO_PUBLIC_HOST% --port %EXPO_PUBLIC_PORT% %EXPO_PUBLIC_LAUNCH_MODE%",
    "prebuild": "expo prebuild",
    "build-android-debug": "cd android && gradlew assembleDebug",
    "build-android-release": "cd android && gradlew assembleRelease",
    "install-android-debug": "cd android && gradlew installDebug",
    "install-android-release": "cd android && gradlew installRelease",
    "build-android-clean": "cd android && gradlew clean",
    "build-web": "expo export --platform web"
  },
  "private": true
}
